# Database — see config/database.php
DB_HOST=localhost
DB_PORT=3306
DB_NAME=dmf_academic
DB_USER=
DB_PASS=

# Auth — see config/auth.php.
# Generate TOKEN_SECRET with: php -r "echo bin2hex(random_bytes(32));"
# Values below match docs/01-PRD.md FR-001 exactly — do not change without
# updating that document first.
TOKEN_SECRET=
TOKEN_TTL=28800
MAX_LOGIN_FAIL=5
LOCKOUT_SEC=300

# AI Diagnostics (optional, FR-015) — leave blank to disable; the rule-based
# recommendation path (FR-014) works regardless.
LLM_API_KEY=

# AI Foundation Layer — see config/ai.php (Sprint 6 Phase 1). No real provider
# exists yet; 'mock' (the only AIProviderInterface implementation this phase
# ships) needs none of these. A future real provider's own API key belongs
# here too, never hardcoded in config/ai.php — LLM_API_KEY above is FR-015's
# older, separate placeholder for the rule-based/optional-LLM path; these
# govern the newer AI Foundation Layer specifically.
AI_DEFAULT_PROVIDER=mock
AI_TIMEOUT=30
AI_TEMPERATURE=0.2
AI_MAX_TOKENS=2048
AI_RETRY=0
AI_PROMPT_VERSION=v1

# Application — see config/app.php
APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=Asia/Bangkok

# DLAP module-specific configuration, read via Dmf\Core\Config\Config::fromEnvironment('DLAP_')
# — see docs/02-System-Architecture.md §16 (Cross-Cutting Concerns) and decisions/IDR-006.
DLAP_SCHOOL_CODE=47010005
